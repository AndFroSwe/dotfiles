{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "os": "#ACB0BE",
    "pink": "#F5BDE6",
    "lavender": "#B7BDF8",
    "blue": "#8AADF4",
    "white": "#FFFFFF",
    "text": "#494D64",
    "battery_charge": "#FFDFD3",
    "battery_low": "#BB5500",
    "battery_full": "#000000"
  },
  "transient_prompt": {
    "background": "transparent",
    "foreground": "p:white",
    "template": "¯»╣ "
  },
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "path",
          "background": "p:blue",
          "foreground": "p:white",
          "leading_diamond": "\u256d\u2500¯éÂ",
          "trailing_diamond": "¯é┤",
          "options": {
            "style": "agnoster",
            "home_icon": "´Çò ",
            "folder_icon": "¯ù¥",
            "folder_separator_icon": " / ",
            "mapped_locations": {
              "~/.config": "¯ÿò",
              "~/Gitrepos": "¾░èó",
              "~/API": "¾░Åù",
              "~/Scratchpad": "¾▒ôº",
              "~/Libs": "´ì╣"
            }
          },
          "style": "diamond",
          "template": " {{ .Path }} "
        },
        {
          "type": "cmake",
          "style": "diamond",
          "trailing_diamond": "¯é┤",
          "foreground": "p:blue",
          "background": "p:white",
          "template": " ¯ÿ× ¯ÿØ cmake "
        },
        {
          "type": "go",
          "style": "diamond",
          "trailing_diamond": "¯é┤",
          "foreground": "p:blue",
          "background": "p:white",
          "template": " ¯ÿº Go "
        },
        {
          "type": "git",
          "style": "diamond",
          "trailing_diamond": "¯é┤",
          "foreground": "p:white",
          "background": "p:lavender",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:os{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#FFCC80{{ end }}",
            "{{ if gt .Ahead 0 }}#B388FF{{ end }}",
            "{{ if gt .Behind 0 }}#B388FB{{ end }}"
          ],
          "template": " {{ .UpstreamIcon }} {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} ´üä {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} ´üå {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} ´âç {{ .StashCount }}{{ end }}",
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "type": "battery",
          "style": "diamond",
          "leading_diamond": "¯éÂ",
          "foreground": "p:text",
          "background": "p:pink",
          "background_templates": [
            "{{if lt .Percentage 25}}p:battery_low{{end}}",
            "{{if eq \"Charging\" .State.String}}p:battery_charge{{end}}",
            "{{if eq \"Full\" .State.String}}p:battery_full{{end}}"
          ],
          "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}´èò ",
          "options": {
            "discharging_icon": "¾▒ƒñ ",
            "charging_icon": "¾░éà ",
            "charged_icon": "¾▒èú "
          }
        },
        {
          "type": "sysinfo",
          "foreground": "p:white",
          "background": "p:blue",
          "leading_diamond": "¯éÂ",
          "style": "diamond",
          "template": " ¯┐à  {{ round .PhysicalPercentUsed .Precision }}% ",
          "options": {
            "precision": 2
          }
        },
        {
          "type": "time",
          "foreground": "p:white",
          "background": "p:lavender",
          "leading_diamond": "¯éÂ",
          "trailing_diamond": "¯é┤",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "diamond",
          "template": "´ü│  {{ .CurrentDate | date .Format }} "
        },
        {
          "type": "executiontime",
          "background": "p:os",
          "foreground": "p:text",
          "leading_diamond": "¯éÂ",
          "trailing_diamond": "¯é┤",
          "options": {
            "style": "austin",
            "threshold": 300
          },
          "style": "diamond",
          "template": "¯Äâ  {{ .FormattedMs }} "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#0c7bbb",
          "style": "plain",
          "template": "\u2570\u2500",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}
